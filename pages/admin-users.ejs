<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="wrap">
    <nav class="nav">
      <a href="/chat">Чат</a>
      <span class="muted"><%= currentUser.username %> (<%= currentUser.role %>)</span>
      <a href="/admin/users">Админ</a>
      <a href="/mod/users">Модерация</a>
      <form method="post" action="/logout" class="inline"><button type="submit">Выйти</button></form>
    </nav>

    <h1>Назначение модераторов</h1>
    <% if (message) { %><p class="flash ok"><%= message %></p><% } %>

    <table>
      <thead>
        <tr><th>ID</th><th>Логин</th><th>Роль</th><th>Действие</th></tr>
      </thead>
      <tbody>
        <% users.forEach(function (u) { %>
          <tr>
            <td><%= u.id %></td>
            <td><%= u.username %></td>
            <td><%= u.role %></td>
            <td>
              <% if (u.id !== currentUser.id && u.role !== 'admin') { %>
                <form method="post" action="/admin/role" class="inline">
                  <input type="hidden" name="user_id" value="<%= u.id %>">
                  <select name="role">
                    <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>user</option>
                    <option value="moderator" <%= u.role === 'moderator' ? 'selected' : '' %>>moderator</option>
                  </select>
                  <button type="submit">Ок</button>
                </form>
              <% } else { %>
                —
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</body>
</html>
